# ============================================================
# n8n Self-Host — fill these, rename to .env, then `docker compose up -d`
# ============================================================

# --- Postgres (n8n internal persistence) ---
N8N_DB_USER=n8n
N8N_DB_PASSWORD=CHANGE_ME_strong_random_32
N8N_DB_NAME=n8n

# --- Public host (Cloudflare Tunnel points here) ---
N8N_HOST=n8n.aura-jonad.com

# --- Encryption + JWT (32+ random chars each) ---
# Generate: `openssl rand -hex 32`
N8N_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32
N8N_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# --- Basic auth (extra lock in front of n8n UI) ---
N8N_BASIC_AUTH_USER=jo
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_strong

# --- Cloudflare Tunnel token ---
# Dashboard → Zero Trust → Networks → Tunnels → Create tunnel → copy token
CF_TUNNEL_TOKEN=eyJhIjoi...paste_here
