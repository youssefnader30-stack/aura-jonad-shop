{
  "name": "Ecom_Phase2_Ops",
  "nodes": [
    {"id": "n_trig", "name": "Cron_6h", "type": "n8n-nodes-base.cron",
     "parameters": {"triggerTimes": {"item": [{"mode": "everyX", "value": 6, "unit": "hours"}]}},
     "position": [100, 400]},
    {"id": "n15", "name": "N15_Health_Agent", "type": "n8n-nodes-base.httpRequest",
     "parameters": {"url": "={{$env.APP_URL}}/api/health", "responseFormat": "json"},
     "position": [320, 400]},
    {"id": "n15if", "name": "Health_OK", "type": "n8n-nodes-base.if",
     "parameters": {"conditions": {"number": [{"value1": "={{$json.status}}", "operation": "equal", "value2": 200}]}},
     "position": [540, 400]},
    {"id": "n22", "name": "N22_Pager", "type": "n8n-nodes-base.slack",
     "parameters": {"channel": "#oncall", "text": "Health check FAILED: {{$json}}"},
     "position": [760, 560]},
    {"id": "n16", "name": "N16_Seed_Agent", "type": "n8n-nodes-base.anthropic",
     "parameters": {"model": "claude-haiku-4-5-20251001",
       "systemPrompt": "Agent: Seed_Agent. Upsert 20 demo products, 3 categories, 1 test user. Idempotent via content hash."},
     "position": [760, 300]},
    {"id": "n17", "name": "N17_Splitter", "type": "n8n-nodes-base.splitInBatches",
     "parameters": {}, "position": [980, 300]},
    {"id": "n18", "name": "N18_SEO_Agent", "type": "n8n-nodes-base.anthropic",
     "parameters": {"model": "claude-haiku-4-5-20251001",
       "systemPrompt": "Agent: SEO_Agent. Regenerate sitemap.xml, robots.txt, and JSON-LD Product schema for all active products."},
     "position": [1200, 160]},
    {"id": "n19", "name": "N19_Email_Agent", "type": "n8n-nodes-base.anthropic",
     "parameters": {"model": "claude-haiku-4-5-20251001",
       "systemPrompt": "Agent: Email_Agent. Publish Resend templates: order_confirmation, order_shipped, refund_issued. Skip if unchanged."},
     "position": [1200, 280]},
    {"id": "n20", "name": "N20_Analytics_Agent", "type": "n8n-nodes-base.anthropic",
     "parameters": {"model": "claude-haiku-4-5-20251001",
       "systemPrompt": "Agent: Analytics_Agent. Flush server-side GA4 events (purchase, add_to_cart) batched in last 5m."},
     "position": [1200, 400]},
    {"id": "n21", "name": "N21_Backup_Agent", "type": "n8n-nodes-base.executeCommand",
     "parameters": {"command": "pg_dump $SUPABASE_DB_URL | gzip | aws s3 cp - s3://$BACKUP_BUCKET/db/$(date +%F).sql.gz"},
     "position": [1200, 520]},
    {"id": "n23", "name": "N23_Merge", "type": "n8n-nodes-base.merge",
     "parameters": {"mode": "combine"}, "position": [1440, 340]},
    {"id": "n24", "name": "N24_QA_v2", "type": "n8n-nodes-base.anthropic",
     "parameters": {"model": "claude-opus-4-6",
       "systemPrompt": "Agent: QA_Agent_v2. Run synthetic e2e against prod: signup→cart→checkout→stripe-test→order. Return {pass,failures}."},
     "position": [1660, 340]},
    {"id": "n24if", "name": "QA_Gate2", "type": "n8n-nodes-base.if",
     "parameters": {"conditions": {"boolean": [{"value1": "={{$json.pass}}", "value2": true}]}},
     "position": [1880, 340]},
    {"id": "n25", "name": "N25_Report", "type": "n8n-nodes-base.slack",
     "parameters": {"channel": "#ecom", "text": "Phase2 OK. KPIs: {{$json.kpis}}"},
     "position": [2100, 240]},
    {"id": "n13", "name": "N13_Retry_Router", "type": "n8n-nodes-base.anthropic",
     "parameters": {"model": "claude-haiku-4-5-20251001",
       "systemPrompt": "Retry_Router. attempt<=2 requeue; else escalate."},
     "position": [2100, 440]}
  ],
  "connections": {
    "Cron_6h":           {"main": [[{"node": "N15_Health_Agent", "type": "main", "index": 0}]]},
    "N15_Health_Agent":  {"main": [[{"node": "Health_OK", "type": "main", "index": 0}]]},
    "Health_OK":         {"main": [
      [{"node": "N16_Seed_Agent", "type": "main", "index": 0}],
      [{"node": "N22_Pager", "type": "main", "index": 0}]
    ]},
    "N16_Seed_Agent":    {"main": [[{"node": "N17_Splitter", "type": "main", "index": 0}]]},
    "N17_Splitter":      {"main": [[
      {"node": "N18_SEO_Agent", "type": "main", "index": 0},
      {"node": "N19_Email_Agent", "type": "main", "index": 0},
      {"node": "N20_Analytics_Agent", "type": "main", "index": 0},
      {"node": "N21_Backup_Agent", "type": "main", "index": 0}
    ]]},
    "N18_SEO_Agent":      {"main": [[{"node": "N23_Merge", "type": "main", "index": 0}]]},
    "N19_Email_Agent":    {"main": [[{"node": "N23_Merge", "type": "main", "index": 1}]]},
    "N20_Analytics_Agent":{"main": [[{"node": "N23_Merge", "type": "main", "index": 2}]]},
    "N21_Backup_Agent":   {"main": [[{"node": "N23_Merge", "type": "main", "index": 3}]]},
    "N23_Merge":          {"main": [[{"node": "N24_QA_v2", "type": "main", "index": 0}]]},
    "N24_QA_v2":          {"main": [[{"node": "QA_Gate2", "type": "main", "index": 0}]]},
    "QA_Gate2":           {"main": [
      [{"node": "N25_Report", "type": "main", "index": 0}],
      [{"node": "N13_Retry_Router", "type": "main", "index": 0}]
    ]}
  }
}
